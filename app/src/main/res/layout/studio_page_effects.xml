<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070707"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:paddingTop="10dp">

        <!-- TEXT SHADOW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="TEXT SHADOW"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drop shadow beneath text"
                        android:textColor="#35FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_shadow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:thumbTint="#FFFFFFFF"
                    android:trackTint="@drawable/switch_track_studio" />

                <TextView
                    android:id="@+id/btn_reset_shadow"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_shadow_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="14dp"
                    android:background="#0CFFFFFF" />

                <!-- Shadow Opacity -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16"
                            android:text="OPACITY"
                            android:textColor="#55FFFFFF"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tv_shadow_opacity_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="100%"
                            android:textColor="#FFE84C3D"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_minus_shadow_opacity"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_reset_shadow_opacity"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_plus_shadow_opacity"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_shadow_opacity"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginBottom="14dp"
                    android:max="100"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progress="100"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio"
                    android:thumbOffset="0dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="14dp"
                    android:background="#0CFFFFFF" />

                <!-- Shadow Offset X -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16"
                            android:text="OFFSET X"
                            android:textColor="#55FFFFFF"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tv_shadow_x_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="4"
                            android:textColor="#FFE84C3D"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_minus_shadow_x"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_reset_shadow_x"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_plus_shadow_x"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_shadow_x"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginBottom="14dp"
                    android:max="200"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progress="104"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio"
                    android:thumbOffset="0dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="14dp"
                    android:background="#0CFFFFFF" />

                <!-- Shadow Offset Y -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16"
                            android:text="OFFSET Y"
                            android:textColor="#55FFFFFF"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tv_shadow_y_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="4"
                            android:textColor="#FFE84C3D"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_minus_shadow_y"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_reset_shadow_y"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_plus_shadow_y"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_shadow_y"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:max="200"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progress="104"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio"
                    android:thumbOffset="0dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- TEXT STROKE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="TEXT STROKE"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Outline around text"
                        android:textColor="#35FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_stroke"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:thumbTint="#FFFFFFFF"
                    android:trackTint="@drawable/switch_track_studio" />
                <!-- FIXED: unique ID for stroke toggle reset (was btn_reset_stroke, same as width reset) -->
                <TextView
                    android:id="@+id/btn_reset_stroke_toggle"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_stroke_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="14dp"
                    android:background="#0CFFFFFF" />

                <!-- Apply to -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.16"
                    android:text="APPLY TO"
                    android:textColor="#55FFFFFF"
                    android:textSize="9sp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:scrollbars="none">

                    <RadioGroup
                        android:id="@+id/rg_stroke_target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_stroke_both"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:checked="true"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Both HH MM"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />

                        <RadioButton
                            android:id="@+id/rb_stroke_hh"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="HH only"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />

                        <RadioButton
                            android:id="@+id/rb_stroke_mm"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="MM only"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />
                    </RadioGroup>
                </HorizontalScrollView>

                <!-- Stroke Width -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16"
                            android:text="WIDTH"
                            android:textColor="#55FFFFFF"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tv_stroke_w_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="3"
                            android:textColor="#FFE84C3D"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_minus_stroke_w"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />
                    <!-- FIXED: unique ID btn_reset_stroke_w (was btn_reset_stroke, clashing with toggle) -->
                    <TextView
                        android:id="@+id/btn_reset_stroke_w"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_plus_stroke_w"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_stroke_w"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginBottom="14dp"
                    android:max="50"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progress="3"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio"
                    android:thumbOffset="0dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="14dp"
                    android:background="#0CFFFFFF" />

                <!-- Stroke Color -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.16"
                    android:text="STROKE COLOR"
                    android:textColor="#55FFFFFF"
                    android:textSize="9sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/swatch_stroke"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/black" />

                    <com.infinity.wallpaper.ui.common.InlineColorPicker
                        android:id="@+id/color_picker_stroke"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="#0CFFFFFF" />

                <!-- Fill Enabled -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16"
                            android:text="FILL ENABLED"
                            android:textColor="#55FFFFFF"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fill colour inside stroke"
                            android:textColor="#35FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_fill_enabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:thumbTint="#FFFFFFFF"
                        android:trackTint="@drawable/switch_track_studio" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- MASK OPACITY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="MASK OPACITY"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_mask_opacity_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:text="100%"
                        android:textColor="#FFE84C3D"
                        android:textSize="20sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_minus_mask_opacity"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_reset_mask_opacity"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_plus_mask_opacity"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_mask_opacity"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:max="100"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progress="100"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio"
                android:thumbOffset="0dp" />
        </LinearLayout>

        <!-- GLOW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Glow Radius -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="GLOW RADIUS"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_glow_radius_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:text="0"
                        android:textColor="#FFE84C3D"
                        android:textSize="20sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_minus_glow_radius"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_reset_glow"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_plus_glow_radius"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_glow_radius"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:max="200"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progress="0"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio"
                android:thumbOffset="0dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"
                android:background="#0CFFFFFF" />

            <!-- Glow Color -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.16"
                android:text="GLOW COLOR"
                android:textColor="#55FFFFFF"
                android:textSize="9sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/swatch_glow"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="12dp"
                    android:background="@color/light_text" />

                <com.infinity.wallpaper.ui.common.InlineColorPicker
                    android:id="@+id/color_picker_glow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>