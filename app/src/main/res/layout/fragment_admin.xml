<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/black">

        <TextView
            android:id="@+id/admin_btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="←"
            android:textColor="@color/light_text"
            android:textSize="20sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Admin Panel"
            android:textColor="@color/light_text"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/accent"/>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="@color/dark_surface">

        <TextView
            android:id="@+id/admin_tab_list"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Wallpapers"
            android:textColor="@color/accent"
            android:textStyle="bold"
            android:textSize="13sp" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/accent"/>

        <TextView
            android:id="@+id/admin_tab_create"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Create New"
            android:textColor="#88EEEEEE"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:id="@+id/admin_tab_indicator"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/accent"/>

    <!-- Content: ViewFlipper with 2 pages -->
    <ViewFlipper
        android:id="@+id/admin_view_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- PAGE 0: List of wallpapers -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/admin_recycler_wallpapers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/admin_list_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="No wallpapers yet"
                android:textColor="#88EEEEEE"
                android:textSize="14sp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/admin_list_loading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/accent"/>
        </FrameLayout>

        <!-- PAGE 1: Create / Edit wallpaper -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <!-- Edit mode banner -->
                <LinearLayout
                    android:id="@+id/admin_edit_banner"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@color/accent_dark"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✏ Editing Wallpaper"
                        android:textColor="@color/light_text"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/admin_btn_cancel_edit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✕ Cancel"
                        android:textColor="@color/light_text"
                        android:textSize="12sp"
                        android:padding="6dp" />
                </LinearLayout>

                <!-- Metadata card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/dark_surface"
                    app:cardCornerRadius="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wallpaper Info"
                            android:textColor="@color/accent"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:layout_marginBottom="10dp"/>

                        <EditText
                            android:id="@+id/admin_et_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Name (used as document ID)"
                            android:textColor="@color/light_text"
                            android:textColorHint="#555555"
                            android:backgroundTint="@color/accent"/>

                        <EditText
                            android:id="@+id/admin_et_category"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:hint="Category (e.g. Abstract, Nature)"
                            android:textColor="@color/light_text"
                            android:textColorHint="#555555"
                            android:backgroundTint="@color/accent"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Premium Wallpaper"
                                android:textColor="@color/light_text" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/admin_sw_premium"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumbTint="@color/accent"
                                android:trackTint="@color/dark_surface"/>
                        </LinearLayout>

                        <!-- Theme count selector -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Number of Themes"
                                android:textColor="@color/light_text"
                                android:textSize="13sp"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:background="@color/dark_surface">

                                <TextView
                                    android:id="@+id/admin_theme_count_1"
                                    android:layout_width="44dp"
                                    android:layout_height="36dp"
                                    android:gravity="center"
                                    android:text="1"
                                    android:textColor="@color/black"
                                    android:textStyle="bold"
                                    android:textSize="13sp"
                                    android:background="@color/accent"/>

                                <TextView
                                    android:id="@+id/admin_theme_count_2"
                                    android:layout_width="44dp"
                                    android:layout_height="36dp"
                                    android:gravity="center"
                                    android:text="2"
                                    android:textColor="#88EEEEEE"
                                    android:textSize="13sp"
                                    android:background="@color/dark_surface"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Image pickers card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/dark_surface"
                    app:cardCornerRadius="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Images"
                            android:textColor="@color/accent"
                            android:textStyle="bold"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/admin_edit_images_note"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Leave empty to keep existing images"
                            android:textColor="#88EEEEEE"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            android:layout_marginBottom="10dp"
                            android:visibility="gone"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/admin_img_bg"
                                    android:layout_width="match_parent"
                                    android:layout_height="120dp"
                                    android:background="@color/black"
                                    android:scaleType="centerCrop" />

                                <TextView
                                    android:id="@+id/admin_btn_pick_bg"
                                    android:layout_width="match_parent"
                                    android:layout_height="36dp"
                                    android:gravity="center"
                                    android:text="Pick BG"
                                    android:textColor="@color/light_text"
                                    android:textSize="12sp"
                                    android:background="@color/accent_dark"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>

                            <View android:layout_width="8dp" android:layout_height="1dp"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/admin_img_mask"
                                    android:layout_width="match_parent"
                                    android:layout_height="120dp"
                                    android:background="@color/black"
                                    android:scaleType="centerCrop" />

                                <TextView
                                    android:id="@+id/admin_btn_pick_mask"
                                    android:layout_width="match_parent"
                                    android:layout_height="36dp"
                                    android:gravity="center"
                                    android:text="Pick Mask"
                                    android:textColor="@color/light_text"
                                    android:textSize="12sp"
                                    android:background="@color/accent_dark"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/admin_img_preview"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/black"
                            android:scaleType="centerCrop" />

                        <TextView
                            android:id="@+id/admin_btn_pick_preview"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="Pick Preview Image"
                            android:textColor="@color/light_text"
                            android:textSize="12sp"
                            android:background="@color/accent_dark"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Theme preview images card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/dark_surface"
                    app:cardCornerRadius="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Theme Preview Images"
                            android:textColor="@color/accent"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Pick a preview image for each theme (shown in style picker)"
                            android:textColor="#88EEEEEE"
                            android:textSize="11sp"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Theme 1 preview -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Style 1"
                                    android:textColor="#AAEEEEEE"
                                    android:textSize="11sp"
                                    android:layout_marginBottom="4dp"/>

                                <ImageView
                                    android:id="@+id/admin_img_theme1_preview"
                                    android:layout_width="match_parent"
                                    android:layout_height="120dp"
                                    android:background="@color/black"
                                    android:scaleType="centerCrop" />

                                <TextView
                                    android:id="@+id/admin_btn_pick_theme1_preview"
                                    android:layout_width="match_parent"
                                    android:layout_height="32dp"
                                    android:gravity="center"
                                    android:text="Pick"
                                    android:textColor="@color/light_text"
                                    android:textSize="11sp"
                                    android:background="@color/accent_dark"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>

                            <View android:layout_width="8dp" android:layout_height="1dp"/>

                            <!-- Theme 2 preview -->
                            <LinearLayout
                                android:id="@+id/admin_theme2_preview_container"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Style 2"
                                    android:textColor="#AAEEEEEE"
                                    android:textSize="11sp"
                                    android:layout_marginBottom="4dp"/>

                                <ImageView
                                    android:id="@+id/admin_img_theme2_preview"
                                    android:layout_width="match_parent"
                                    android:layout_height="120dp"
                                    android:background="@color/black"
                                    android:scaleType="centerCrop" />

                                <TextView
                                    android:id="@+id/admin_btn_pick_theme2_preview"
                                    android:layout_width="match_parent"
                                    android:layout_height="32dp"
                                    android:gravity="center"
                                    android:text="Pick"
                                    android:textColor="@color/light_text"
                                    android:textSize="11sp"
                                    android:background="@color/accent_dark"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/admin_btn_open_studio"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Open Studio"
                        android:textStyle="bold"
                        android:textColor="@color/light_text"
                        android:textSize="14sp"
                        android:background="@color/dark_surface" />

                    <View android:layout_width="10dp" android:layout_height="1dp"/>

                    <TextView
                        android:id="@+id/admin_btn_upload"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Upload"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:background="@color/accent" />
                </LinearLayout>

                <!-- Hidden compat field -->
                <EditText
                    android:id="@+id/admin_et_theme1_json"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"/>
            </LinearLayout>
        </ScrollView>
    </ViewFlipper>
</LinearLayout>
