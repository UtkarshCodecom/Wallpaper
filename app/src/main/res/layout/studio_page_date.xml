<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070707"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:paddingTop="10dp">

        <!-- Display Date Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="DATE VISIBILITY"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show date below clock"
                        android:textColor="#35FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_date_visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:thumbTint="#FFFFFFFF"
                    android:trackTint="@drawable/switch_track_studio" />

                <TextView
                    android:id="@+id/btn_reset_date_visible"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>
        </LinearLayout>



        <!-- Date Layer (Mask Order) -->
        <LinearLayout
            android:id="@+id/layout_date_layer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="DATE LAYER"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Place date above or below the mask"
                        android:textColor="#35FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_date_above_mask"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:thumbTint="#FFFFFFFF"
                    android:trackTint="@drawable/switch_track_studio" />

                <TextView
                    android:id="@+id/btn_reset_date_above_mask"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>
        </LinearLayout>

        <!-- DATE TRANSPARENCY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="DATE TRANSPARENCY"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_date_opacity_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:text="100%"
                        android:textColor="#FFE84C3D"
                        android:textSize="20sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_minus_date_opacity"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_reset_date_opacity"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_plus_date_opacity"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_date_opacity"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:max="100"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progress="100"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio"
                android:thumbOffset="0dp" />
        </LinearLayout>

        <!-- Date controls -->
        <LinearLayout
            android:id="@+id/layout_date_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- DATE SIZE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/studio_card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16"
                            android:text="DATE SIZE"
                            android:textColor="#55FFFFFF"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tv_date_size_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="40sp"
                            android:textColor="#FFE84C3D"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_minus_date_size"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_reset_date_size"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_plus_date_size"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_date_size"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:max="200"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progress="40"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio"
                    android:thumbOffset="0dp" />
            </LinearLayout>

            <!-- X OFFSET -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/studio_card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16"
                            android:text="X OFFSET"
                            android:textColor="#55FFFFFF"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tv_date_x_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="50%"
                            android:textColor="#FFE84C3D"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_minus_date_x"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_reset_date_x"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_plus_date_x"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_date_x"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:max="100"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progress="50"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio"
                    android:thumbOffset="0dp" />
            </LinearLayout>

            <!-- Y OFFSET -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/studio_card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16"
                            android:text="Y OFFSET"
                            android:textColor="#55FFFFFF"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tv_date_y_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="75%"
                            android:textColor="#FFE84C3D"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_minus_date_y"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_reset_date_y"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_plus_date_y"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_date_y"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:max="100"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progress="75"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio"
                    android:thumbOffset="0dp" />
            </LinearLayout>

            <!-- TILT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/studio_card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16"
                            android:text="TILT"
                            android:textColor="#55FFFFFF"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tv_date_rot_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="0°"
                            android:textColor="#FFE84C3D"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_minus_date_rot"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_reset_date_rot"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />

                    <TextView
                        android:id="@+id/btn_plus_date_rot"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_date_rot"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:max="360"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progress="180"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio"
                    android:thumbOffset="0dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>