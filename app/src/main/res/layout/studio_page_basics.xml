<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070707"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:paddingTop="10dp">

        <!-- Custom Image Upload Block -->


        <include layout="@layout/studio_basics_opacity_block" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="TEXT SCALE"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_size_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:text="520"
                        android:textColor="#FFE84C3D"
                        android:textSize="20sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_minus_size"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_plus_size"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_reset_size"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_size"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:max="1200"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progress="520"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio"
                android:thumbOffset="0dp" />
        </LinearLayout>

        <!-- TILT (Moved from Transform) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="ROTATION"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_rot_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:text="0°"
                        android:textColor="#FFE84C3D"
                        android:textSize="20sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_rot_90_plus"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="+90°"
                    android:textColor="@color/accent"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/btn_minus_rot"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_reset_rot"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_plus_rot"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_rot"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:max="360"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progress="180"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio"
                android:thumbOffset="0dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="X OFFSET"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_posx_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:text="50%"
                        android:textColor="#FFE84C3D"
                        android:textSize="20sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_minus_posx"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_plus_posx"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_reset_posx"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_posx"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:max="100"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progress="50"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio"
                android:thumbOffset="0dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:text="Y OFFSET"
                        android:textColor="#55FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_posy_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:text="65%"
                        android:textColor="#FFE84C3D"
                        android:textSize="20sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_minus_posy"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_plus_posy"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />

                <TextView
                    android:id="@+id/btn_reset_posy"
                    android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/studio_reset_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="↺"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/studio_reset_icon" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_posy"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:max="100"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progress="65"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio"
                android:thumbOffset="0dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/studio_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.16"
                android:text="CUSTOM BACKGROUND"
                android:textColor="#55FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.16"
                android:text="Apply a wallapper from app and upload your custom background image to enjoy same time style on favorite image."
                android:textAlignment="center"
                android:textColor="#55FFFFFF"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/btn_upload_custom_bg"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@color/accent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="UPLOAD FROM GALLERY"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_remove_custom_bg"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="REMOVE CUSTOM BACKGROUND"
                android:textColor="#FFE84C3D"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>


    </LinearLayout>
</ScrollView>