<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:orientation="vertical">

    <!-- Preview area (centered) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:background="@color/black">

        <FrameLayout
            android:id="@+id/studio_preview_frame"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_bg"
            android:clipToOutline="true">

            <!-- Composited preview bitmap (bg+mask+text) -->
            <ImageView
                android:id="@+id/studio_preview_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/dark_surface"
                android:contentDescription="preview"
                android:scaleType="centerCrop" />

            <!-- Hidden legacy refs -->
            <ImageView
                android:id="@+id/studio_preview_bg"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/studio_preview_mask"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/studio_preview_progress"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/accent"
                android:visibility="gone" />


        </FrameLayout>

        <TextView
            android:id="@+id/btn_studio_reset"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="-25dp"
            android:layout_marginBottom="5dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:rotation="90"
            android:text="Reset"
            android:textColor="@color/accent"
            android:textSize="18sp" />
    </FrameLayout>

    <!-- Editor: tabs + pages -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4.7"
        android:background="@color/black"
        android:orientation="vertical">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/studio_tabs"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@color/dark_surface"
            app:tabGravity="start"
            app:tabIndicatorColor="@color/accent"
            app:tabMode="scrollable"
            app:tabSelectedTextColor="@color/accent"
            app:tabTextColor="@color/light_text" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/studio_viewpager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000" />
    </LinearLayout>

</LinearLayout>
