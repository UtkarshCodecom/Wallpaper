<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <ImageView
        android:id="@+id/fullscreen_preview_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true" />

    <!-- Info overlay at bottom -->
    <LinearLayout
        android:id="@+id/fullscreen_info_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#CC000000">

        <TextView
            android:id="@+id/fullscreen_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFEEEEEE"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/fullscreen_category"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#AAD84040"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/fullscreen_apply_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFD84040"
                android:textSize="13sp"
                android:text="👥 0 users applied" />
        </LinearLayout>
    </LinearLayout>

    <!-- Close button -->
    <TextView
        android:id="@+id/fullscreen_close"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:gravity="center"
        android:text="✕"
        android:textColor="#FFEEEEEE"
        android:textSize="20sp"
        android:background="#AA000000" />
</FrameLayout>
