<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A">

    <!-- Header: title + reset -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#111111">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Wallpaper Studio"
            android:textColor="@color/light_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <TextView
            android:id="@+id/btn_studio_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↺ Reset"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:background="@color/dark_surface"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Preview area (centered) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:background="@color/black"
        android:gravity="center"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/studio_preview_frame"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@color/black">

            <!-- Composited preview bitmap (bg+mask+text) -->
            <ImageView
                android:id="@+id/studio_preview_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="preview"
                android:scaleType="fitXY"
                android:background="@color/dark_surface" />

            <!-- Hidden legacy refs -->
            <ImageView
                android:id="@+id/studio_preview_bg"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/studio_preview_mask"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/studio_preview_progress"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/accent"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- Editor: tabs + pages -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:orientation="vertical"
        android:background="@color/black">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/studio_tabs"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@color/dark_surface"
            app:tabMode="scrollable"
            app:tabGravity="start"
            app:tabIndicatorColor="@color/accent"
            app:tabTextColor="@color/light_text"
            app:tabSelectedTextColor="@color/accent" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/studio_viewpager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000" />
    </LinearLayout>

</LinearLayout>
