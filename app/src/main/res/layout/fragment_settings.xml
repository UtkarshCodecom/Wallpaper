<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.20"
                    android:text="SETTINGS"
                    android:textColor="#40FFFFFF"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:text="@string/title_settings"
                    android:textColor="@color/white"
                    android:textSize="26sp" />
            </LinearLayout>

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="⚙"
                android:textColor="#30FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- ── Clock Display ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.20"
            android:text="CLOCK DISPLAY"
            android:textColor="#40FFFFFF"
            android:textSize="9sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical">

            <!-- Lock screen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Lock screen clock"
                        android:textColor="@color/light_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Show time on lock screen"
                        android:textColor="#35FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_lock_clock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/white"
                    android:trackTint="@drawable/switch_track_studio" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:background="#0AFFFFFF" />

            <!-- Home screen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Home screen clock"
                        android:textColor="@color/light_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Show time on home screen"
                        android:textColor="#35FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_home_clock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/white"
                    android:trackTint="@drawable/switch_track_studio" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:background="#0AFFFFFF" />

            <!-- 24h -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="24-hour format"
                        android:textColor="@color/light_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Use 24h instead of 12h"
                        android:textColor="#35FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_24hour"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/white"
                    android:trackTint="@drawable/switch_track_studio" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Clock Animation ───────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.20"
            android:text="ANIMATION"
            android:textColor="#40FFFFFF"
            android:textSize="9sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Clock animation"
                        android:textColor="@color/light_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Animate on minute change"
                        android:textColor="#35FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_clock_anim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/white"
                    android:trackTint="@drawable/switch_track_studio" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_anim_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="20dp"
                    android:background="#0AFFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.18"
                    android:text="STYLE"
                    android:textColor="#40FFFFFF"
                    android:textSize="9sp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <RadioGroup
                        android:id="@+id/radio_anim_style"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/anim_style_0"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Fade"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />

                        <RadioButton
                            android:id="@+id/anim_style_1"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Slide Up"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />

                        <RadioButton
                            android:id="@+id/anim_style_2"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Slide Down"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />

                        <RadioButton
                            android:id="@+id/anim_style_3"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Slide Left"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />

                        <RadioButton
                            android:id="@+id/anim_style_4"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Slide Right"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />

                        <RadioButton
                            android:id="@+id/anim_style_5"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Stretch V"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />

                        <RadioButton
                            android:id="@+id/anim_style_6"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Stretch In"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />

                        <RadioButton
                            android:id="@+id/anim_style_7"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Parallax"
                            android:textColor="@drawable/chip_yellow_text_selector"
                            android:textSize="12sp" />
                    </RadioGroup>
                </HorizontalScrollView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.18"
                    android:text="SPEED"
                    android:textColor="#40FFFFFF"
                    android:textSize="9sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <SeekBar
                        android:id="@+id/seek_anim_speed"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progressDrawable="@drawable/seekbar_track_studio"
                        android:thumb="@drawable/seekbar_thumb_studio"
                        android:thumbOffset="0dp" />

                    <TextView
                        android:id="@+id/tv_anim_speed_value"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="sans-serif-light"
                        android:gravity="end"
                        android:text="Normal"
                        android:textColor="@color/accent"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Motion ────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.20"
            android:text="MOTION"
            android:textColor="#40FFFFFF"
            android:textSize="9sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/studio_card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Gyroscope effect"
                        android:textColor="@color/light_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Tilt phone to move clock"
                        android:textColor="#35FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_gyro_enabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/white"
                    android:trackTint="@drawable/switch_track_studio" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_gyro_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="20dp"
                    android:background="#0AFFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.18"
                    android:text="MODE"
                    android:textColor="#40FFFFFF"
                    android:textSize="9sp" />

                <RadioGroup
                    android:id="@+id/radio_motion_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radio_motion_tilt"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/chip_yellow_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:text="3D Tilt"
                        android:textColor="@drawable/chip_yellow_text_selector"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/radio_motion_shift"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/chip_yellow_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:text="Shift"
                        android:textColor="@drawable/chip_yellow_text_selector"
                        android:textSize="13sp" />
                </RadioGroup>

                <!-- Sensitivity -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.18"
                    android:text="SENSITIVITY"
                    android:textColor="#40FFFFFF"
                    android:textSize="9sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <SeekBar
                        android:id="@+id/seek_motion_sensitivity"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progressDrawable="@drawable/seekbar_track_studio"
                        android:thumb="@drawable/seekbar_thumb_studio"
                        android:thumbOffset="0dp" />

                    <TextView
                        android:id="@+id/tv_sens_value"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="sans-serif-light"
                        android:gravity="end"
                        android:text="50"
                        android:textColor="@color/accent"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Amount -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.18"
                    android:text="AMOUNT"
                    android:textColor="#40FFFFFF"
                    android:textSize="9sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <SeekBar
                        android:id="@+id/seek_motion_amount"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:max="200"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progressDrawable="@drawable/seekbar_track_studio"
                        android:thumb="@drawable/seekbar_thumb_studio"
                        android:thumbOffset="0dp" />

                    <TextView
                        android:id="@+id/tv_amount_value"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="sans-serif-light"
                        android:gravity="end"
                        android:text="80"
                        android:textColor="@color/accent"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

