<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <!-- Full-screen composited wallpaper preview -->
    <ImageView
        android:id="@+id/wp_preview_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:contentDescription="Wallpaper preview" />

    <!-- Loading spinner centered -->
    <ProgressBar
        android:id="@+id/wp_preview_loading"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFD84040"
        android:visibility="gone" />

    <!-- Status text (Downloading / Rendering) -->
    <TextView
        android:id="@+id/wp_preview_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="64dp"
        android:textColor="#FFEEEEEE"
        android:textSize="13sp"
        android:background="#88000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- Close button top-right -->
    <TextView
        android:id="@+id/wp_preview_close"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:gravity="center"
        android:text="✕"
        android:textColor="#FFEEEEEE"
        android:textSize="18sp"
        android:background="#AA000000" />

    <!-- Bottom overlay: name + category + Set as Wallpaper button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="20dp">

        <TextView
            android:id="@+id/wp_preview_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFEEEEEE"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/wp_preview_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAEEEEEE"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/wp_preview_btn_set"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="Set as Wallpaper"
            android:textColor="#FF000000"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="#FFD84040" />
    </LinearLayout>

</FrameLayout>
