<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#070707" android:scrollbars="none">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp" android:paddingTop="10dp">

        <include layout="@layout/studio_basics_opacity_block"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/studio_card_bg"
            android:padding="16dp" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="FONT SIZE" android:textColor="#55FFFFFF" android:textSize="9sp"
                        android:letterSpacing="0.16" android:fontFamily="sans-serif-medium" android:layout_marginBottom="3dp"/>
                    <TextView android:id="@+id/tv_size_val" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="520" android:textColor="#FFE84C3D"
                        android:textSize="20sp" android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <TextView android:id="@+id/btn_minus_size" android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch" android:text="−"
                    android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn_plus_size" android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch" android:text="+"
                    android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:layout_marginStart="8dp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn_reset_size" android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch" android:text="↺"
                    android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:layout_marginStart="8dp" android:clickable="true" android:focusable="true"/>
            </LinearLayout>
            <SeekBar android:id="@+id/seek_size" android:layout_width="match_parent"
                android:layout_height="36dp" android:max="1200" android:progress="520"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio" android:thumbOffset="0dp"
                android:paddingStart="0dp" android:paddingEnd="0dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/studio_card_bg"
            android:padding="16dp" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HORIZONTAL POSITION" android:textColor="#55FFFFFF" android:textSize="9sp"
                        android:letterSpacing="0.16" android:fontFamily="sans-serif-medium" android:layout_marginBottom="3dp"/>
                    <TextView android:id="@+id/tv_posx_val" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="50%" android:textColor="#FFE84C3D"
                        android:textSize="20sp" android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <TextView android:id="@+id/btn_minus_posx" android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch" android:text="−"
                    android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn_plus_posx" android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch" android:text="+"
                    android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:layout_marginStart="8dp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn_reset_posx" android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch" android:text="↺"
                    android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:layout_marginStart="8dp" android:clickable="true" android:focusable="true"/>
            </LinearLayout>
            <SeekBar android:id="@+id/seek_posx" android:layout_width="match_parent"
                android:layout_height="36dp" android:max="100" android:progress="50"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio" android:thumbOffset="0dp"
                android:paddingStart="0dp" android:paddingEnd="0dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/studio_card_bg"
            android:padding="16dp" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="VERTICAL POSITION" android:textColor="#55FFFFFF" android:textSize="9sp"
                        android:letterSpacing="0.16" android:fontFamily="sans-serif-medium" android:layout_marginBottom="3dp"/>
                    <TextView android:id="@+id/tv_posy_val" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="65%" android:textColor="#FFE84C3D"
                        android:textSize="20sp" android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <TextView android:id="@+id/btn_minus_posy" android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch" android:text="−"
                    android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn_plus_posy" android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch" android:text="+"
                    android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:layout_marginStart="8dp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn_reset_posy" android:layout_width="@dimen/studio_reset_touch"
                    android:layout_height="@dimen/studio_reset_touch" android:text="↺"
                    android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:layout_marginStart="8dp" android:clickable="true" android:focusable="true"/>
            </LinearLayout>
            <SeekBar android:id="@+id/seek_posy" android:layout_width="match_parent"
                android:layout_height="36dp" android:max="100" android:progress="65"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio" android:thumbOffset="0dp"
                android:paddingStart="0dp" android:paddingEnd="0dp"/>
        </LinearLayout>



    </LinearLayout>
</ScrollView>