<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <FrameLayout
        android:id="@+id/top_nav_container"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_gravity="top"
        android:layout_margin="16dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        android:background="@drawable/bg_nav_oval"
        android:elevation="6dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/top_navigation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:paddingBottom="0dp"
            app:labelVisibilityMode="labeled"
            app:itemIconSize="18dp"
            app:itemTextAppearanceActive="@style/TextAppearance.BottomNav.Active"
            app:itemTextAppearanceInactive="@style/TextAppearance.BottomNav.Inactive"
            app:itemTextColor="@color/nav_item_color_state"
            app:itemRippleColor="@color/nav_item_inactive"
            app:itemActiveIndicatorStyle="@color/nav_item_inactive"
            app:menu="@menu/bottom_nav_menu" />

        <View
            android:id="@+id/bottom_indicator"
            android:layout_width="56dp"
            android:layout_height="4dp"
            android:layout_gravity="bottom"
            android:background="@color/accent" />

    </FrameLayout>

    <!-- Split container -->
    <FrameLayout
        android:id="@+id/split_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="70dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!--
            Main panel: pivot top-left, scales down toward left when settings opens.
            Width is set to MINI_SCALE * screenWidth in code so it doesn't
            intercept touches meant for the settings panel.
        -->
        <FrameLayout
            android:id="@+id/nav_host_fragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!--
            Settings panel: slides in from the right.
            Contains the fragment + a drag strip on its left edge.
        -->
        <FrameLayout
            android:id="@+id/settings_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@color/black"
            android:elevation="4dp"
            android:clipChildren="false">

            <!-- Settings fragment content fills the whole panel -->
            <FrameLayout
                android:id="@+id/settings_fragment_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Drag strip: ONLY on the left edge so content stays touchable -->
            <View
                android:id="@+id/settings_drag_strip"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:background="@android:color/transparent"
                android:elevation="8dp" />

        </FrameLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>